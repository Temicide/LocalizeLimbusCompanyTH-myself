{
  "dataList": [
    {
      "id": 1,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "ชัยชนะอยู่ในกำมือเราแล้วครับ กลยุทธ์ของท่านช่างน่าเลื่อมใสยิ่งนัก",
      "usage": "(800101, VERY_HIGH), (800102, VERY_HIGH), (800104, VERY_HIGH), (800105, VERY_HIGH)"
    },
    {
      "id": 2,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "สถานการณ์กำลังเป็นใจให้เรา โปรดปล่อยให้เป็นหน้าที่ของข้าพเจ้าเถิดครับ",
      "usage": "(800101, HIGH), (800102, HIGH), (800104, HIGH), (800105, HIGH) "
    },
    {
      "id": 3,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "หากท่านเลือกส่งข้าพเจ้าไป ข้าพเจ้าจะไม่ทำให้ท่านต้องผิดหวังอย่างแน่นอนครับ",
      "usage": "(800101, NORMAL), (800102, NORMAL), (800104, NORMAL), (800105, NORMAL)"
    },
    {
      "id": 4,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "แม้แผนการจะดูรัดกุมดี แต่ข้าพเจ้าเกรงว่าความสามารถของข้าพเจ้าอาจจะยังไม่เพียงพอสำหรับงานนี้ครับ",
      "usage": "(800101, LOW), (800102, LOW), (800104, LOW), (800105, LOW)"
    },
    {
      "id": 5,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "ใครมันเป็นคนคิดแผนเฮงซวยแบ— อ่า... เมื่อครู่เป็นมุกตลกใช่ไหมครับ?",
      "usage": "(800101, VERY_LOW), (800102, VERY_LOW), (800104, VERY_LOW), (800105, VERY_LOW) "
    },
    {
      "id": 6,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "ชัยชนะในครั้งนี้เกิดขึ้นได้เพราะการวางแผนอันยอดเยี่ยมของท่านเพียงผู้เดียวครับ",
      "usage": "(800101, SUCCESS), (800102, SUCCESS), (800104, SUCCESS), (800105, SUCCESS)"
    },
    {
      "id": 7,
      "personalityid": 11101,
      "voiceFile": 0,
      "teller": "อูทิส",
      "dialog": "เป็นความผิดของข้าพเจ้าเอง...",
      "usage": "(800101, FAILURE), (800102, FAILURE), (800104, FAILURE), (800105, FAILURE)"
    },
